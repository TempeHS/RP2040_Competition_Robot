{
  "name": "MicroPython Pico Build Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/RP2040_Competition_Robot",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "editor.formatOnSave": true
      },
      "extensions": [
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "esbenp.prettier-vscode",
        "GitHub.codespaces",
        "mathematic.vscode-pdf",
        "McCarter.start-git-bash",
        "mechatroner.rainbow-csv",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.pylint",
        "ms-python.python",
        "ms-python.vscode-python-envs",
        "narasimapandiyan.jetbrainsmono",
        "oderwat.indent-rainbow",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-british-english",
        "yusifaliyevpro.vscicons",
        "saeris.markdown-github-alerts",
        "benpaddlejones.pico-bridge"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/setup_environment.sh"
}
